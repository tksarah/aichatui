# .env.example (簡易)
# コピーして `.env` にし、値を入力してください。

PORT=3000                # サーバー待ち受けポート
ALLOWED_ORIGIN=https://chat.example.com
CADDY_DOMAIN=chat.example.com
CHAT_HISTORY_TTL_MINUTES=30
SESSION_HISTORY_VISIBLE_COUNT=10

USE_MOCK_LLM=false       # true でモック応答

LLM_PROVIDER=            # openai または gemini（未指定で判定）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

ALLOWED_MODELS=          # カンマ区切りで許可モデル
ENABLE_MODEL_SWITCH=false

# 注意: 実際の API キーはリポジトリに含めないでください。
