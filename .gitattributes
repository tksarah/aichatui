# Normalize text files to LF in the repository.
* text=auto

# Force LF for common text file types.
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
README.md text eol=lf
docker-compose.yml text eol=lf

# Treat common image formats as binary.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary

# Do not include local push instructions in exported archives.
PUSHING.md export-ignore
